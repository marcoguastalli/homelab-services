# duplicati — copy to /srv/homelab/secrets/duplicati.env on the Pi,
# mode 0600 (RB-002). Double duty: the container reads it via env_file
# AND homelab-ops verify-backup.sh / restore-stack.sh source it — keep
# all six variables present.
TZ=Europe/Berlin

# Web UI login + settings-db encryption (Duplicati 2.x).
DUPLICATI__WEBSERVICE_PASSWORD=changeme
SETTINGS_ENCRYPTION_KEY=changeme-openssl-rand-hex-32

# --- ops contract (verify-backup.sh, restore-stack.sh) ---------------
# Backup target as seen INSIDE the container:
DUPLICATI_URL=file:///backup/homelab
# THE passphrase. Also in the password manager AND on paper — it is the
# single point of failure of the whole DR story (architecture/007).
DUPLICATI_PASSPHRASE=changeme
# MUST match the image pin in compose.yaml:
DUPLICATI_IMAGE=duplicati/duplicati:2.3.0.3
# Host path of the backup set (freshness check):
BACKUP_TARGET_DIR=/mnt/backup/homelab
