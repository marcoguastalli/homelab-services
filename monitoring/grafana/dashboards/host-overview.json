{
  "uid": "host-overview",
  "title": "Host Overview",
  "tags": ["homelab"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU usage",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "min": 0}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))",
          "legendFormat": "cpu busy"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory used",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "min": 0}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes",
          "legendFormat": "memory used"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Root filesystem free",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "min": 0}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/rootfs\"} / node_filesystem_size_bytes{mountpoint=\"/rootfs\"}",
          "legendFormat": "free"
        },
        {
          "refId": "B",
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}",
          "legendFormat": "free (/)"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU temperature",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {"defaults": {"unit": "celsius"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "node_thermal_zone_temp",
          "legendFormat": "{{type}}"
        }
      ]
    }
  ]
}
