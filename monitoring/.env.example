# monitoring — copy to /srv/homelab/secrets/monitoring.env on the Pi
# (RB-002). Consumed by the grafana service.
TZ=Europe/Berlin
GF_SECURITY_ADMIN_USER=marco
GF_SECURITY_ADMIN_PASSWORD=changeme
#
# Alertmanager's ntfy topic URLs are files, not env vars (Alertmanager
# has no env expansion; webhook url_file is the supported secret path).
# Create on the Pi, mode 0600:
#   /srv/homelab/secrets/monitoring/ntfy-critical-url
#     https://ntfy.sh/<long-random-topic>?title=homelab+CRITICAL&priority=urgent
#   /srv/homelab/secrets/monitoring/ntfy-warning-url
#     https://ntfy.sh/<long-random-topic>?title=homelab+warning&priority=default
# The topic name IS the credential — generate with: openssl rand -hex 16
