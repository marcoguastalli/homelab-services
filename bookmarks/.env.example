# bookmarks — copy to /srv/homelab/secrets/bookmarks.env on the Pi,
# mode 0600 (RB-002). One file feeds both containers: POSTGRES_PASSWORD
# (consumed by bookmarks-db) and DATABASE_URL (consumed by the app)
# must use the same password. Generate with: openssl rand -hex 24
TZ=Europe/Madrid
POSTGRES_PASSWORD=changeme-openssl-rand-hex-24
DATABASE_URL=postgres://bookmarks:changeme-openssl-rand-hex-24@bookmarks-db:5432/bookmarks
# Optional app tuning:
# MAX_FOLDER_DEPTH=5
